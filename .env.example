# ─── APIs ─────────────────────────────────────────────────────────────
NVD_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_CTI=
# TELEGRAM_CHAT_ID_CVE=

# Lista de IDs de chat autorizados a interagir via comandos.
# Exemplo: TELEGRAM_ALLOWED_CHATS="-1001234567,98765432" (se vazio, usa CTI ID)
TELEGRAM_ALLOWED_CHATS=

# ─── Groq LLM (obrigatória — summarização CTI) ──────────────────────
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Thresholds e janelas de tempo ───────────────────────────────────
# NEWS_TIME_WINDOW_MINUTES=60     # intervalo do pipeline CTI
# CVE_SCHEDULE_MINUTES=60         # intervalo do pipeline CVE (janela NVD é sempre >=24h)
# MIN_CVSS_SCORE=2.0
# CISA_KEV_CACHE_HOURS=24
# MAX_CVE_AGE_DAYS=30
# MIN_CTI_SCORE=40                # pesos das categorias vêm de data/cti_categories.json

# ─── Caminhos (resolvidos como absolutos pelo config.py) ─────────────
# BOT_DB_PATH=./data/bot_database.db
# ASSETS_CACHE_PATH=./data/clients_assets.xlsx
# CTI_FEEDS_PATH=./data/cti_feeds.json

# ─── Patch Tuesday (MSRC) ────────────────────────────────────────────
# Relatório mensal da Microsoft. Roda na 2ª terça do mês (UTC).
# PATCH_TUESDAY_ENABLED=true
# TELEGRAM_CHAT_ID_PATCH=          # se vazio, usa o canal de CVE (ou CTI)
# PATCH_TUESDAY_FORMATS=pdf        # anexos: pdf | csv | xlsx (lista: "pdf,xlsx")
# PATCH_TUESDAY_HOUR=18            # hora UTC do disparo na 2ª terça
# PATCH_TUESDAY_MINUTE=30
# MSRC_FETCH_RETRIES=8             # poll caso o documento ainda não esteja publicado
# MSRC_FETCH_RETRY_SLEEP=300       # segundos entre tentativas
# REPORTS_OUTPUT_DIR=./data/reports

# ─── Logging ─────────────────────────────────────────────────────────
# LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
